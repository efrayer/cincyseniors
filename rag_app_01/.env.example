# ── OpenAI ─────────────────────────────────────────────────────────────────
# Required for TTS (text-to-speech) via OpenAI
OPENAI_API_KEY=sk-...

# ── Text-to-Speech ─────────────────────────────────────────────────────────
TTS_ENGINE=openai          # openai | browser
TTS_VOICE=nova             # alloy | echo | fable | onyx | nova | shimmer
TTS_MODEL=tts-1
TTS_INSTRUCTIONS=          # Optional: custom voice instructions

# ── Admin API Key ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must match the value set in your admin HTML pages (see docs/setup.md)
ADMIN_API_KEY=your-64-hex-char-key-here

# ── LLM (optional: local LLM via LM Studio or similar) ────────────────────
# Leave blank to use OpenAI. Set to a local endpoint to run fully offline.
LLM_BASE_URL=
LLM_API_KEY=
